<?xml version="1.0"?>
<rdf:RDF xmlns="http://www.semanticweb.org/se7slocal/ontologies/2025/9/untitled-ontology-7/"
     xml:base="http://www.semanticweb.org/se7slocal/ontologies/2025/9/untitled-ontology-7/"
     xmlns:owl="http://www.w3.org/2002/07/owl#"
     xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
     xmlns:xml="http://www.w3.org/XML/1998/namespace"
     xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
     xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
     xmlns:swrl="http://www.w3.org/2003/11/swrl#"
     xmlns:swrla="http://swrl.stanford.edu/ontologies/3.3/swrla.owl#"
     xmlns:swrlb="http://www.w3.org/2003/11/swrlb#"
     xmlns:ontology="http://www.semanticSports.org/ontology#">
    <owl:Ontology rdf:about="http://www.semanticSports.org/ontology#">
        <rdfs:comment>This ontology models a football domain including players, coaches, teams, matches, tournaments, positions, and performance metrics. It captures relationships such as player participation, match performance, coaching roles, and tournament structure. The ontology includes reasoning constraints, cardinality restrictions, and inverse properties to ensure semantic consistency and enable inference.</rdfs:comment>
    </owl:Ontology>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Annotation properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- http://swrl.stanford.edu/ontologies/3.3/swrla.owl#isRuleEnabled -->

    <owl:AnnotationProperty rdf:about="http://swrl.stanford.edu/ontologies/3.3/swrla.owl#isRuleEnabled"/>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Object Properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- http://www.semanticSports.org/ontology#coachesTeam -->

    <owl:ObjectProperty rdf:about="http://www.semanticSports.org/ontology#coachesTeam">
        <owl:inverseOf rdf:resource="http://www.semanticSports.org/ontology#hasCoach"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://www.semanticSports.org/ontology#Coach"/>
        <rdfs:range rdf:resource="http://www.semanticSports.org/ontology#Team"/>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticSports.org/ontology#forMatch -->

    <owl:ObjectProperty rdf:about="http://www.semanticSports.org/ontology#forMatch">
        <rdfs:domain rdf:resource="http://www.semanticSports.org/ontology#PerformanceMetric"/>
        <rdfs:range rdf:resource="http://www.semanticSports.org/ontology#Match"/>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticSports.org/ontology#hasCoach -->

    <owl:ObjectProperty rdf:about="http://www.semanticSports.org/ontology#hasCoach">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://www.semanticSports.org/ontology#Team"/>
        <rdfs:range rdf:resource="http://www.semanticSports.org/ontology#Coach"/>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticSports.org/ontology#hasMatch -->

    <owl:ObjectProperty rdf:about="http://www.semanticSports.org/ontology#hasMatch">
        <owl:inverseOf rdf:resource="http://www.semanticSports.org/ontology#partOfTournament"/>
        <rdfs:domain rdf:resource="http://www.semanticSports.org/ontology#Tournament"/>
        <rdfs:range rdf:resource="http://www.semanticSports.org/ontology#Match"/>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticSports.org/ontology#hasPerformance -->

    <owl:ObjectProperty rdf:about="http://www.semanticSports.org/ontology#hasPerformance">
        <rdfs:domain rdf:resource="http://www.semanticSports.org/ontology#Player"/>
        <rdfs:range rdf:resource="http://www.semanticSports.org/ontology#PerformanceMetric"/>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticSports.org/ontology#hasPlayer -->

    <owl:ObjectProperty rdf:about="http://www.semanticSports.org/ontology#hasPlayer">
        <rdfs:domain rdf:resource="http://www.semanticSports.org/ontology#Team"/>
        <rdfs:range rdf:resource="http://www.semanticSports.org/ontology#Player"/>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticSports.org/ontology#hasPosition -->

    <owl:ObjectProperty rdf:about="http://www.semanticSports.org/ontology#hasPosition">
        <rdfs:domain rdf:resource="http://www.semanticSports.org/ontology#Player"/>
        <rdfs:range rdf:resource="http://www.semanticSports.org/ontology#Position"/>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticSports.org/ontology#hasTeam -->

    <owl:ObjectProperty rdf:about="http://www.semanticSports.org/ontology#hasTeam">
        <rdfs:domain rdf:resource="http://www.semanticSports.org/ontology#Player"/>
        <rdfs:range rdf:resource="http://www.semanticSports.org/ontology#Team"/>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticSports.org/ontology#partOfTournament -->

    <owl:ObjectProperty rdf:about="http://www.semanticSports.org/ontology#partOfTournament">
        <rdfs:domain rdf:resource="http://www.semanticSports.org/ontology#Match"/>
        <rdfs:range rdf:resource="http://www.semanticSports.org/ontology#Tournament"/>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticSports.org/ontology#participatesIn -->

    <owl:ObjectProperty rdf:about="http://www.semanticSports.org/ontology#participatesIn">
        <rdfs:domain rdf:resource="http://www.semanticSports.org/ontology#Team"/>
        <rdfs:range rdf:resource="http://www.semanticSports.org/ontology#Tournament"/>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticSports.org/ontology#playedIn -->

    <owl:ObjectProperty rdf:about="http://www.semanticSports.org/ontology#playedIn">
        <rdfs:domain rdf:resource="http://www.semanticSports.org/ontology#Player"/>
        <rdfs:range rdf:resource="http://www.semanticSports.org/ontology#Match"/>
    </owl:ObjectProperty>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Data properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- http://www.semanticSports.org/ontology#hasPerformanceRating -->

    <owl:DatatypeProperty rdf:about="http://www.semanticSports.org/ontology#hasPerformanceRating">
        <rdfs:domain rdf:resource="http://www.semanticSports.org/ontology#PerformanceMetric"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#float"/>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticSports.org/ontology#madeAssists -->

    <owl:DatatypeProperty rdf:about="http://www.semanticSports.org/ontology#madeAssists">
        <rdfs:domain rdf:resource="http://www.semanticSports.org/ontology#PerformanceMetric"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticSports.org/ontology#matchDate -->

    <owl:DatatypeProperty rdf:about="http://www.semanticSports.org/ontology#matchDate">
        <rdfs:domain rdf:resource="http://www.semanticSports.org/ontology#Match"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#dateTime"/>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticSports.org/ontology#playedMinutes -->

    <owl:DatatypeProperty rdf:about="http://www.semanticSports.org/ontology#playedMinutes">
        <rdfs:domain rdf:resource="http://www.semanticSports.org/ontology#Player"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticSports.org/ontology#scoredGoals -->

    <owl:DatatypeProperty rdf:about="http://www.semanticSports.org/ontology#scoredGoals">
        <rdfs:domain rdf:resource="http://www.semanticSports.org/ontology#PerformanceMetric"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
    </owl:DatatypeProperty>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Classes
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- http://www.semanticSports.org/ontology#Coach -->

    <owl:Class rdf:about="http://www.semanticSports.org/ontology#Coach">
        <owl:disjointWith rdf:resource="http://www.semanticSports.org/ontology#Player"/>
        <owl:disjointWith rdf:resource="http://www.semanticSports.org/ontology#Position"/>
    </owl:Class>
    


    <!-- http://www.semanticSports.org/ontology#Defender -->

    <owl:Class rdf:about="http://www.semanticSports.org/ontology#Defender">
        <rdfs:subClassOf rdf:resource="http://www.semanticSports.org/ontology#Position"/>
    </owl:Class>
    


    <!-- http://www.semanticSports.org/ontology#Forward -->

    <owl:Class rdf:about="http://www.semanticSports.org/ontology#Forward">
        <rdfs:subClassOf rdf:resource="http://www.semanticSports.org/ontology#Position"/>
    </owl:Class>
    


    <!-- http://www.semanticSports.org/ontology#Goalkeeper -->

    <owl:Class rdf:about="http://www.semanticSports.org/ontology#Goalkeeper">
        <rdfs:subClassOf rdf:resource="http://www.semanticSports.org/ontology#Position"/>
    </owl:Class>
    


    <!-- http://www.semanticSports.org/ontology#Match -->

    <owl:Class rdf:about="http://www.semanticSports.org/ontology#Match">
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.semanticSports.org/ontology#forMatch"/>
                <owl:minQualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:minQualifiedCardinality>
                <owl:onClass rdf:resource="http://www.semanticSports.org/ontology#PerformanceMetric"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.semanticSports.org/ontology#hasPerformance"/>
                <owl:minQualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:minQualifiedCardinality>
                <owl:onClass rdf:resource="http://www.semanticSports.org/ontology#PerformanceMetric"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.semanticSports.org/ontology#partOfTournament"/>
                <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
                <owl:onClass rdf:resource="http://www.semanticSports.org/ontology#Tournament"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.semanticSports.org/ontology#matchDate"/>
                <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
                <owl:onDataRange rdf:resource="http://www.w3.org/2001/XMLSchema#dateTime"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <owl:disjointWith rdf:resource="http://www.semanticSports.org/ontology#Team"/>
    </owl:Class>
    


    <!-- http://www.semanticSports.org/ontology#Midfielder -->

    <owl:Class rdf:about="http://www.semanticSports.org/ontology#Midfielder">
        <rdfs:subClassOf rdf:resource="http://www.semanticSports.org/ontology#Position"/>
    </owl:Class>
    


    <!-- http://www.semanticSports.org/ontology#PerformanceMetric -->

    <owl:Class rdf:about="http://www.semanticSports.org/ontology#PerformanceMetric">
        <owl:disjointWith rdf:resource="http://www.semanticSports.org/ontology#Team"/>
    </owl:Class>
    


    <!-- http://www.semanticSports.org/ontology#Player -->

    <owl:Class rdf:about="http://www.semanticSports.org/ontology#Player">
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.semanticSports.org/ontology#hasPerformance"/>
                <owl:minQualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">0</owl:minQualifiedCardinality>
                <owl:onClass rdf:resource="http://www.semanticSports.org/ontology#PerformanceMetric"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.semanticSports.org/ontology#playedIn"/>
                <owl:minQualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">0</owl:minQualifiedCardinality>
                <owl:onClass rdf:resource="http://www.semanticSports.org/ontology#Match"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.semanticSports.org/ontology#hasPosition"/>
                <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
                <owl:onClass rdf:resource="http://www.semanticSports.org/ontology#Position"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.semanticSports.org/ontology#hasTeam"/>
                <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
                <owl:onClass rdf:resource="http://www.semanticSports.org/ontology#Team"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <owl:disjointWith rdf:resource="http://www.semanticSports.org/ontology#Team"/>
    </owl:Class>
    


    <!-- http://www.semanticSports.org/ontology#Position -->

    <owl:Class rdf:about="http://www.semanticSports.org/ontology#Position"/>
    


    <!-- http://www.semanticSports.org/ontology#Team -->

    <owl:Class rdf:about="http://www.semanticSports.org/ontology#Team">
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.semanticSports.org/ontology#hasPlayer"/>
                <owl:allValuesFrom rdf:resource="http://www.semanticSports.org/ontology#Player"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.semanticSports.org/ontology#hasPlayer"/>
                <owl:minQualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:minQualifiedCardinality>
                <owl:onClass rdf:resource="http://www.semanticSports.org/ontology#Player"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.semanticSports.org/ontology#participatesIn"/>
                <owl:minQualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:minQualifiedCardinality>
                <owl:onClass rdf:resource="http://www.semanticSports.org/ontology#Tournament"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.semanticSports.org/ontology#hasCoach"/>
                <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
                <owl:onClass rdf:resource="http://www.semanticSports.org/ontology#Coach"/>
            </owl:Restriction>
        </rdfs:subClassOf>
    </owl:Class>
    


    <!-- http://www.semanticSports.org/ontology#Tournament -->

    <owl:Class rdf:about="http://www.semanticSports.org/ontology#Tournament">
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.semanticSports.org/ontology#partOfTournament"/>
                <owl:minQualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:minQualifiedCardinality>
                <owl:onClass rdf:resource="http://www.semanticSports.org/ontology#Match"/>
            </owl:Restriction>
        </rdfs:subClassOf>
    </owl:Class>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Individuals
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- http://www.semanticSports.org/ontology#AlexisMacAllister -->

    <owl:NamedIndividual rdf:about="http://www.semanticSports.org/ontology#AlexisMacAllister">
        <rdf:type rdf:resource="http://www.semanticSports.org/ontology#Player"/>
        <ontology:hasPerformance rdf:resource="http://www.semanticSports.org/ontology#Perf201"/>
        <ontology:hasPerformance rdf:resource="http://www.semanticSports.org/ontology#Perf202"/>
        <ontology:hasPerformance rdf:resource="http://www.semanticSports.org/ontology#Perf203"/>
        <ontology:hasPosition rdf:resource="http://www.semanticSports.org/ontology#MidfielderPos"/>
        <ontology:hasTeam rdf:resource="http://www.semanticSports.org/ontology#LiverpoolFC"/>
        <ontology:playedIn rdf:resource="http://www.semanticSports.org/ontology#Match101"/>
        <ontology:playedIn rdf:resource="http://www.semanticSports.org/ontology#Match102"/>
        <ontology:playedIn rdf:resource="http://www.semanticSports.org/ontology#Match103"/>
    </owl:NamedIndividual>
    


    <!-- http://www.semanticSports.org/ontology#CodyGakpo -->

    <owl:NamedIndividual rdf:about="http://www.semanticSports.org/ontology#CodyGakpo">
        <rdf:type rdf:resource="http://www.semanticSports.org/ontology#Player"/>
        <ontology:hasPerformance rdf:resource="http://www.semanticSports.org/ontology#Perf701"/>
        <ontology:hasPerformance rdf:resource="http://www.semanticSports.org/ontology#Perf702"/>
        <ontology:hasPerformance rdf:resource="http://www.semanticSports.org/ontology#Perf703"/>
        <ontology:hasPosition rdf:resource="http://www.semanticSports.org/ontology#ForwardPos"/>
        <ontology:hasTeam rdf:resource="http://www.semanticSports.org/ontology#LiverpoolFC"/>
        <ontology:playedIn rdf:resource="http://www.semanticSports.org/ontology#Match101"/>
        <ontology:playedIn rdf:resource="http://www.semanticSports.org/ontology#Match102"/>
        <ontology:playedIn rdf:resource="http://www.semanticSports.org/ontology#Match103"/>
    </owl:NamedIndividual>
    


    <!-- http://www.semanticSports.org/ontology#DarwinNunez -->

    <owl:NamedIndividual rdf:about="http://www.semanticSports.org/ontology#DarwinNunez">
        <rdf:type rdf:resource="http://www.semanticSports.org/ontology#Player"/>
        <ontology:hasPerformance rdf:resource="http://www.semanticSports.org/ontology#Perf301"/>
        <ontology:hasPerformance rdf:resource="http://www.semanticSports.org/ontology#Perf302"/>
        <ontology:hasPerformance rdf:resource="http://www.semanticSports.org/ontology#Perf303"/>
        <ontology:hasPosition rdf:resource="http://www.semanticSports.org/ontology#ForwardPos"/>
        <ontology:hasTeam rdf:resource="http://www.semanticSports.org/ontology#LiverpoolFC"/>
        <ontology:playedIn rdf:resource="http://www.semanticSports.org/ontology#Match101"/>
        <ontology:playedIn rdf:resource="http://www.semanticSports.org/ontology#Match102"/>
        <ontology:playedIn rdf:resource="http://www.semanticSports.org/ontology#Match103"/>
    </owl:NamedIndividual>
    


    <!-- http://www.semanticSports.org/ontology#DefenderPos -->

    <owl:NamedIndividual rdf:about="http://www.semanticSports.org/ontology#DefenderPos">
        <rdf:type rdf:resource="http://www.semanticSports.org/ontology#Defender"/>
    </owl:NamedIndividual>
    


    <!-- http://www.semanticSports.org/ontology#ForwardPos -->

    <owl:NamedIndividual rdf:about="http://www.semanticSports.org/ontology#ForwardPos">
        <rdf:type rdf:resource="http://www.semanticSports.org/ontology#Forward"/>
    </owl:NamedIndividual>
    


    <!-- http://www.semanticSports.org/ontology#GoalkeeperPos -->

    <owl:NamedIndividual rdf:about="http://www.semanticSports.org/ontology#GoalkeeperPos">
        <rdf:type rdf:resource="http://www.semanticSports.org/ontology#Goalkeeper"/>
    </owl:NamedIndividual>
    


    <!-- http://www.semanticSports.org/ontology#JurgenKlopp -->

    <owl:NamedIndividual rdf:about="http://www.semanticSports.org/ontology#JurgenKlopp">
        <rdf:type rdf:resource="http://www.semanticSports.org/ontology#Coach"/>
    </owl:NamedIndividual>
    


    <!-- http://www.semanticSports.org/ontology#LiverpoolFC -->

    <owl:NamedIndividual rdf:about="http://www.semanticSports.org/ontology#LiverpoolFC">
        <rdf:type rdf:resource="http://www.semanticSports.org/ontology#Team"/>
        <ontology:hasCoach rdf:resource="http://www.semanticSports.org/ontology#JurgenKlopp"/>
        <ontology:participatesIn rdf:resource="http://www.semanticSports.org/ontology#PremierLeague"/>
    </owl:NamedIndividual>
    


    <!-- http://www.semanticSports.org/ontology#LuisDiaz -->

    <owl:NamedIndividual rdf:about="http://www.semanticSports.org/ontology#LuisDiaz">
        <rdf:type rdf:resource="http://www.semanticSports.org/ontology#Player"/>
        <ontology:hasPerformance rdf:resource="http://www.semanticSports.org/ontology#Perf401"/>
        <ontology:hasPerformance rdf:resource="http://www.semanticSports.org/ontology#Perf402"/>
        <ontology:hasPerformance rdf:resource="http://www.semanticSports.org/ontology#Perf403"/>
        <ontology:hasPosition rdf:resource="http://www.semanticSports.org/ontology#ForwardPos"/>
        <ontology:hasTeam rdf:resource="http://www.semanticSports.org/ontology#LiverpoolFC"/>
        <ontology:playedIn rdf:resource="http://www.semanticSports.org/ontology#Match101"/>
        <ontology:playedIn rdf:resource="http://www.semanticSports.org/ontology#Match102"/>
        <ontology:playedIn rdf:resource="http://www.semanticSports.org/ontology#Match103"/>
    </owl:NamedIndividual>
    


    <!-- http://www.semanticSports.org/ontology#Match101 -->

    <owl:NamedIndividual rdf:about="http://www.semanticSports.org/ontology#Match101">
        <rdf:type rdf:resource="http://www.semanticSports.org/ontology#Match"/>
        <ontology:partOfTournament rdf:resource="http://www.semanticSports.org/ontology#PremierLeague"/>
        <ontology:matchDate rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2024-09-15T15:00:00</ontology:matchDate>
    </owl:NamedIndividual>
    


    <!-- http://www.semanticSports.org/ontology#Match102 -->

    <owl:NamedIndividual rdf:about="http://www.semanticSports.org/ontology#Match102">
        <rdf:type rdf:resource="http://www.semanticSports.org/ontology#Match"/>
        <ontology:partOfTournament rdf:resource="http://www.semanticSports.org/ontology#PremierLeague"/>
        <ontology:matchDate rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2024-10-04T15:00:00</ontology:matchDate>
    </owl:NamedIndividual>
    


    <!-- http://www.semanticSports.org/ontology#Match103 -->

    <owl:NamedIndividual rdf:about="http://www.semanticSports.org/ontology#Match103">
        <rdf:type rdf:resource="http://www.semanticSports.org/ontology#Match"/>
        <ontology:partOfTournament rdf:resource="http://www.semanticSports.org/ontology#PremierLeague"/>
        <ontology:matchDate rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2024-10-15T15:00:00</ontology:matchDate>
    </owl:NamedIndividual>
    


    <!-- http://www.semanticSports.org/ontology#MidfielderPos -->

    <owl:NamedIndividual rdf:about="http://www.semanticSports.org/ontology#MidfielderPos">
        <rdf:type rdf:resource="http://www.semanticSports.org/ontology#Midfielder"/>
        <ontology:hasPosition rdf:resource="http://www.semanticSports.org/ontology#MidfielderPos"/>
    </owl:NamedIndividual>
    


    <!-- http://www.semanticSports.org/ontology#MohamedSalah -->

    <owl:NamedIndividual rdf:about="http://www.semanticSports.org/ontology#MohamedSalah">
        <rdf:type rdf:resource="http://www.semanticSports.org/ontology#Player"/>
        <ontology:hasPerformance rdf:resource="http://www.semanticSports.org/ontology#Perf101"/>
        <ontology:hasPerformance rdf:resource="http://www.semanticSports.org/ontology#Perf102"/>
