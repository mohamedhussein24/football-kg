ont:Team a owl:Class ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:minQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onClass ont:Tournament ;
            owl:onProperty ont:participatesIn ],
        [ a owl:Restriction ;
            owl:allValuesFrom ont:Player ;
            owl:onProperty ont:hasPlayer ],
        [ a owl:Restriction ;
            owl:minQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onClass ont:Player ;
            owl:onProperty ont:hasPlayer ],
        [ a owl:Restriction ;
            owl:onClass ont:Coach ;
            owl:onProperty ont:hasCoach ;
            owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ] .

ont:Match a owl:Class ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onDataRange xsd:dateTime ;
            owl:onProperty ont:matchDate ;
            owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ],
        [ a owl:Restriction ;
            owl:minQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onClass ont:PerformanceMetric ;
            owl:onProperty ont:hasPerformance ],
        [ a owl:Restriction ;
            owl:onClass ont:Tournament ;
            owl:onProperty ont:partOfTournament ;
            owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ],
        [ a owl:Restriction ;
            owl:minQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onClass ont:PerformanceMetric ;
            owl:onProperty ont:forMatch ] ;
    owl:disjointWith ont:Team .

ont:Player a owl:Class ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onClass ont:Team ;
            owl:onProperty ont:hasTeam ;
            owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ],
        [ a owl:Restriction ;
            owl:minQualifiedCardinality "0"^^xsd:nonNegativeInteger ;
            owl:onClass ont:Match ;
            owl:onProperty ont:playedIn ],
        [ a owl:Restriction ;
            owl:onClass ont:Position ;
            owl:onProperty ont:hasPosition ;
            owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ],
        [ a owl:Restriction ;
            owl:minQualifiedCardinality "0"^^xsd:nonNegativeInteger ;
            owl:onClass ont:PerformanceMetric ;
            owl:onProperty ont:hasPerformance ] ;
    owl:disjointWith ont:Team .

ont:PerformanceMetric a owl:Class ;
    owl:disjointWith ont:Team .

[] a swrl:Imp ;
    rdfs:label "FatigueRiskRule" ;
    swrla:isRuleEnabled true ;
    rdfs:comment "" ;
    swrl:body [ a swrl:AtomList ;
            rdf:first [ a swrl:ClassAtom ;
                    swrl:argument1 :p ;
                    swrl:classPredicate ont:Player ] ;
            rdf:rest [ a swrl:AtomList ;
                    rdf:first [ a swrl:DatavaluedPropertyAtom ;
                            swrl:argument1 :p ;
                            swrl:argument2 :m ;
                            swrl:propertyPredicate ont:playedMinutes ] ;
                    rdf:rest [ a swrl:AtomList ;
                            rdf:first [ a swrl:BuiltinAtom ;
                                    swrl:arguments [ a rdf:List ;
                                            rdf:first :m ;
                                            rdf:rest [ a rdf:List ;
                                                    rdf:first 85 ;
                                                    rdf:rest () ] ] ;
                                    swrl:builtin swrlb:greaterThan ] ;
                            rdf:rest () ] ] ] ;
    swrl:head [ a swrl:AtomList ;
            rdf:first [ a swrl:DatavaluedPropertyAtom ;
                    swrl:argument1 :p ;
                    swrl:argument2 4.5 ;
                    swrl:propertyPredicate ont:hasPerformanceRating ] ;
            rdf:rest () ] .

[] a swrl:Imp ;
    rdfs:label "ExcellentPlayerRule" ;
    swrla:isRuleEnabled true ;
    rdfs:comment "" ;
    swrl:body [ a swrl:AtomList ;
            rdf:first [ a swrl:ClassAtom ;
                    swrl:argument1 :p ;
                    swrl:classPredicate ont:Player ] ;
            rdf:rest [ a swrl:AtomList ;
                    rdf:first [ a swrl:DatavaluedPropertyAtom ;
                            swrl:argument1 :p ;
                            swrl:argument2 :g ;
                            swrl:propertyPredicate ont:scoredGoals ] ;
                    rdf:rest [ a swrl:AtomList ;
                            rdf:first [ a swrl:DatavaluedPropertyAtom ;
                                    swrl:argument1 :p ;
                                    swrl:argument2 :a ;
                                    swrl:propertyPredicate ont:madeAssists ] ;
                            rdf:rest [ a swrl:AtomList ;
                                    rdf:first [ a swrl:BuiltinAtom ;
                                            swrl:arguments [ a rdf:List ;
                                                    rdf:first :g ;
                                                    rdf:rest [ a rdf:List ;
                                                            rdf:first 1 ;
                                                            rdf:rest () ] ] ;
                                            swrl:builtin swrlb:greaterThan ] ;
                                    rdf:rest [ a swrl:AtomList ;
                                            rdf:first [ a swrl:BuiltinAtom ;
                                                    swrl:arguments [ a rdf:List ;
                                                            rdf:first :a ;
                                                            rdf:rest [ a rdf:List ;
                                                                    rdf:first 0 ;
                                                                    rdf:rest () ] ] ;
                                                    swrl:builtin swrlb:greaterThan ] ;
                                            rdf:rest () ] ] ] ] ] ;
    swrl:head [ a swrl:AtomList ;
            rdf:first [ a swrl:DatavaluedPropertyAtom ;
                    swrl:argument1 :p ;
                    swrl:argument2 9.5 ;
                    swrl:propertyPredicate ont:hasPerformanceRating ] ;
            rdf:rest () ] .

