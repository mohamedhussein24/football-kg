ont: a owl:Ontology ;
    rdfs:comment "This ontology models a football domain including players, coaches, teams, matches, tournaments, positions, and performance metrics. It captures relationships such as player participation, match performance, coaching roles, and tournament structure. The ontology includes reasoning constraints, cardinality restrictions, and inverse properties to ensure semantic consistency and enable inference." .

ont:GoalkeeperPos a ont:Goalkeeper,
        owl:NamedIndividual .

ont:birthDate a rdf:Property .

ont:birthPlace a rdf:Property .

ont:coachesTeam a owl:FunctionalProperty,
        owl:ObjectProperty ;
    rdfs:domain ont:Coach ;
    rdfs:range ont:Team ;
    owl:inverseOf ont:hasCoach .

ont:country a rdf:Property .

ont:foundedDate a rdf:Property .

ont:hasMatch a owl:ObjectProperty ;
    rdfs:domain ont:Tournament ;
    rdfs:range ont:Match ;
    owl:inverseOf ont:partOfTournament .

ont:height a rdf:Property .

ont:nationality a rdf:Property .

